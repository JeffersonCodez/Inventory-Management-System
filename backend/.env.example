# Copy this file to .env and fill in real values. Never commit the real
# .env — it's already in .gitignore.

# Server
PORT=4000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:5173

# MySQL — matches database/schema.sql in the project root
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user_here
DB_PASSWORD=your_db_password_here
DB_NAME=ledger_inventory

# Auth — generate a real secret with: openssl rand -hex 32
JWT_SECRET=replace_this_with_a_real_random_secret
JWT_EXPIRES_IN=2h

# Email (Sign Up verification codes + Forgot Password reset codes).
# Leave these unset during local development and the app will log OTP
# codes to the console instead of emailing them — see backend/src/utils/mailer.js.
# For a real deployment, any standard SMTP provider works, e.g.:
#   - Gmail: smtp.gmail.com, port 587, an "App Password" (requires 2FA enabled)
#   - Resend / Brevo / Mailtrap: a free tier is usually enough for a small business
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_8JiXUtQe_DB3AzgY8PgWWkwkwt2dtZwqa
SMTP_FROM="Ledger Inventory <Jeffersonsepara22@gmail.com>"
